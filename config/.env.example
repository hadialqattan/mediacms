# Service Ports (each service has its own default)
PORT=8080              # Override for any service

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mediacms?sslmode=disable
DB_MAX_CONNECTIONS=25

# Default Admin
DEFAULT_ADMIN_EMAIL=admin@mediacms.local
DEFAULT_ADMIN_PASSWORD=changeme

# Redis
REDIS_ADDR=localhost:6379
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=500ms
REDIS_MAX_RETRY_BACKOFF=1s

# Typesense
TYPESENSE_ADDRESS=http://localhost:8108
TYPESENSE_API_KEY=xyz

# JWT
JWT_SECRET=secret-key-change-in-production
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

# Outbox Relay
OUTBOX_RELAY_INTERVAL=5s
